# Optional: Arweave wallet address (same as the JWK in PATH_TO_KEYFILE).
# full-crawl.mjs loads the latest on-chain crawl-log tagged doctype=crawllog for this owner.
# AGENT_WALLET=
# PATH_TO_KEYFILE=./arweave-keyfile-....json

# Molecule crawler (full-crawl.mjs and crawlers/molecule/crawler)
# MOLECULE_API_KEY=your-x-api-key

# Optional: override default https://arweave.net/graphql
# ARWEAVE_GRAPHQL_URL=
